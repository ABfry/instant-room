{
  "name": "instant-room",
  "version": "0.1.0",
  "description": "Ephemeral collaboration rooms — just share a URL",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./adapters/y-websocket": {
      "types": "./dist/infrastructure/adapters/y-websocket-entry.d.ts",
      "import": "./dist/infrastructure/adapters/y-websocket-entry.mjs",
      "require": "./dist/infrastructure/adapters/y-websocket-entry.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/",
    "format": "prettier --write src/ tests/",
    "typecheck": "tsc --noEmit",
    "example:basic": "tsx examples/01-basic-room.ts",
    "example:custom-ttl": "tsx examples/02-custom-ttl.ts",
    "example:ttl-expiration": "tsx examples/03-ttl-expiration.ts",
    "example:participants": "tsx examples/04-participants.ts"
  },
  "keywords": [
    "yjs",
    "collaboration",
    "ephemeral",
    "room",
    "realtime",
    "crdt",
    "websocket",
    "hocuspocus",
    "url-sharing"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ABfry/instant-room.git"
  },
  "homepage": "https://github.com/ABfry/instant-room",
  "bugs": {
    "url": "https://github.com/ABfry/instant-room/issues"
  },
  "dependencies": {
    "lib0": "^0.2.117",
    "ms": "^2.1.3",
    "nanoid": "^5.0.9"
  },
  "peerDependencies": {
    "y-protocols": ">=1.0.0",
    "yjs": ">=13.6.0"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@hocuspocus/server": "^2.15.0",
    "@types/ms": "^2.0.0",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@vitest/coverage-v8": "^3.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.4.0",
    "tsup": "^8.3.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0",
    "ws": "^8.19.0",
    "y-protocols": "^1.0.6",
    "yjs": "^13.6.0"
  }
}
